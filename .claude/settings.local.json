{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npx tsc:*)",
      "Bash(npm run:*)",
      "Bash(grep -v \"^$\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(./node_modules/.bin/tsc --noEmit --incremental false)",
      "Bash(./node_modules/.bin/tsc --noEmit)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)"
    ]
  }
}
